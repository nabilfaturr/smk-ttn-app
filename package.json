{
  "name": "smk-ttn-app",
  "version": "1.0.0",
  "private": true,
  "description": "Sistem Absensi dan Pengelolaan Nilai Siswa SMK Taruna Tekno Nusantara",
  "author": {
    "name": "SMK Taruna Tekno Nusantara",
    "email": "admin@smkttn.sch.id"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "start": "NODE_ENV=production electron .",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "vite build",
    "build:win": "tsc && vite build && electron-builder --win --x64",
    "demo:check": "node scripts/demo-check.mjs",
    "build:win:portable": "tsc && vite build && electron-builder --win portable --x64",
    "release:win": "node scripts/release-win.mjs",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:unit": "npm rebuild better-sqlite3 > /dev/null 2>&1 && vitest run",
    "test:rebuild-electron": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed/index.ts --mode=default",
    "db:seed:full": "tsx scripts/seed/index.ts --mode=full",
    "db:seed:test": "tsx scripts/seed/index.ts --mode=test",
    "db:seed:reset": "tsx scripts/seed/index.ts --reset",
    "db:fresh:full": "tsx scripts/seed/index.ts --reset --mode=full --force",
    "db:fresh:default": "tsx scripts/seed/index.ts --reset --mode=default --force",
    "db:fresh:test": "tsx scripts/seed/index.ts --reset --mode=test --force",
    "sync:cleanup": "tsx scripts/sync-cleanup.ts",
    "sync:initial-push": "tsx scripts/sync-initial-push.ts",
    "build:embedded-migrations": "node scripts/build-embedded-migrations.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.13",
    "@radix-ui/react-label": "^2.1.5",
    "@radix-ui/react-popover": "^1.1.13",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.8",
    "@radix-ui/react-toast": "^1.2.13",
    "@radix-ui/react-tooltip": "^1.2.6",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docxtemplater": "^3.69.0",
    "drizzle-orm": "^0.43.1",
    "firebase": "^11.6.1",
    "lucide-react": "^0.510.0",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.16.0",
    "pizzip": "^3.2.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.6.7",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.2",
    "react-router-dom": "^7.6.2",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@tailwindcss/vite": "^4.1.6",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "docx": "^9.7.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^33.4.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^3.1.3",
    "wait-on": "^8.0.3"
  }
}
